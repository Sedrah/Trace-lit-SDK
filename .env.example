# AMO — Self-hosted configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# API Keys
# ---------------------------------------------------------------------------
# Maps SDK api_key → org_id. JSON string.
# Self-hosted single-org installs: leave as-is (keyless mode returns "default").
# To require a key: '{"sk-your-key-here": "default"}'
AMO_API_KEYS={}

# Set to true to skip API key checks entirely (convenient for self-host).
AMO_ALLOW_KEYLESS=true

# ---------------------------------------------------------------------------
# Kafka
# ---------------------------------------------------------------------------
AMO_KAFKA_BROKERS=kafka:9092
AMO_RAW_TOPIC=amo.spans.raw
AMO_NORMALIZED_TOPIC=amo.spans.normalized
AMO_METRICS_TOPIC=amo.metrics

# ---------------------------------------------------------------------------
# ClickHouse
# ---------------------------------------------------------------------------
AMO_CLICKHOUSE_HOST=clickhouse
AMO_CLICKHOUSE_PORT=8123
AMO_CLICKHOUSE_DATABASE=amo
AMO_CLICKHOUSE_USER=amo
AMO_CLICKHOUSE_PASSWORD=amo_clickhouse_password

# ---------------------------------------------------------------------------
# TimescaleDB / PostgreSQL
# ---------------------------------------------------------------------------
AMO_TIMESCALE_DSN=postgresql://amo:amo_pg_password@timescaledb:5432/amo
POSTGRES_USER=amo
POSTGRES_PASSWORD=amo_pg_password
POSTGRES_DB=amo

# ---------------------------------------------------------------------------
# API server
# ---------------------------------------------------------------------------
AMO_API_HOST=0.0.0.0
AMO_API_PORT=8000
AMO_CORS_ORIGINS=http://localhost:3000,http://localhost:80
AMO_KEY_CACHE_TTL_S=300

# ---------------------------------------------------------------------------
# Ingestion pipeline
# ---------------------------------------------------------------------------
AMO_CH_BATCH_SIZE=500
AMO_CH_FLUSH_INTERVAL_S=2.0
AMO_TS_BATCH_SIZE=1000
AMO_TS_FLUSH_INTERVAL_S=5.0

# ---------------------------------------------------------------------------
# Model pricing overrides (optional)
# Format: '{"model-name": {"input_per_1m": 1.0, "output_per_1m": 3.0}}'
# ---------------------------------------------------------------------------
AMO_MODEL_PRICING=

# ---------------------------------------------------------------------------
# Data retention
# ---------------------------------------------------------------------------
# ClickHouse TTL is set in the schema (90 days). Override here if needed.
AMO_TRACE_TTL_DAYS=90

# ---------------------------------------------------------------------------
# Dashboard
# ---------------------------------------------------------------------------
# The public URL where the dashboard is reachable (used by nginx)
AMO_DASHBOARD_PORT=3000
