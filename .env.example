# Trace-lit — Self-hosted configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# Your Hetzner server's public IP address.
# Used by Kafka EXTERNAL listener so SDK clients can connect from outside.
SERVER_IP=YOUR_SERVER_IP_HERE

# ---------------------------------------------------------------------------
# API Keys
# ---------------------------------------------------------------------------
# Maps SDK api_key → org_id. JSON string.
# Self-hosted single-org installs: leave as-is (keyless mode returns "default").
# To require a key: '{"sk-your-key-here": "default"}'
TRACELIT_API_KEYS={}

# Set to true to skip API key checks entirely (convenient for self-host).
TRACELIT_ALLOW_KEYLESS=true

# Admin API key — protects POST/GET/DELETE /api/v1/admin/keys.
# Generate with: python3 -c "import secrets; print('sk-admin-' + secrets.token_urlsafe(32))"
# Leave unset to disable the admin API entirely.
TRACELIT_ADMIN_KEY=

# ---------------------------------------------------------------------------
# Kafka
# ---------------------------------------------------------------------------
TRACELIT_KAFKA_BROKERS=kafka:9092
TRACELIT_RAW_TOPIC=trace_lit.spans.raw
TRACELIT_NORMALIZED_TOPIC=trace_lit.spans.normalized
TRACELIT_METRICS_TOPIC=trace_lit.metrics

# ---------------------------------------------------------------------------
# ClickHouse
# ---------------------------------------------------------------------------
TRACELIT_CLICKHOUSE_HOST=clickhouse
TRACELIT_CLICKHOUSE_PORT=8123
TRACELIT_CLICKHOUSE_DATABASE=trace_lit
TRACELIT_CLICKHOUSE_USER=tracelit
TRACELIT_CLICKHOUSE_PASSWORD=tracelit_clickhouse_password

# ---------------------------------------------------------------------------
# TimescaleDB / PostgreSQL
# ---------------------------------------------------------------------------
TRACELIT_TIMESCALE_DSN=postgresql://tracelit:tracelit_pg_password@timescaledb:5432/trace_lit
POSTGRES_USER=tracelit
POSTGRES_PASSWORD=tracelit_pg_password
POSTGRES_DB=trace_lit

# ---------------------------------------------------------------------------
# API server
# ---------------------------------------------------------------------------
TRACELIT_API_HOST=0.0.0.0
TRACELIT_API_PORT=8000
TRACELIT_CORS_ORIGINS=http://localhost:3000,http://localhost:80
TRACELIT_KEY_CACHE_TTL_S=300

# ---------------------------------------------------------------------------
# Ingestion pipeline
# ---------------------------------------------------------------------------
TRACELIT_CH_BATCH_SIZE=500
TRACELIT_CH_FLUSH_INTERVAL_S=2.0
TRACELIT_TS_BATCH_SIZE=1000
TRACELIT_TS_FLUSH_INTERVAL_S=5.0

# ---------------------------------------------------------------------------
# Model pricing overrides (optional)
# Format: '{"model-name": {"input_per_1m": 1.0, "output_per_1m": 3.0}}'
# ---------------------------------------------------------------------------
TRACELIT_MODEL_PRICING=

# ---------------------------------------------------------------------------
# Data retention
# ---------------------------------------------------------------------------
# ClickHouse TTL is set in the schema (90 days). Override here if needed.
TRACELIT_TRACE_TTL_DAYS=90

# ---------------------------------------------------------------------------
# Dashboard
# ---------------------------------------------------------------------------
# The public URL where the dashboard is reachable (used by nginx)
TRACELIT_DASHBOARD_PORT=3000
